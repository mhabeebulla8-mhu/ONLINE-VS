# Environment Configuration
# Copy this file to .env or .env.local and fill in your values

# ===== AADHAAR OTP VERIFICATION =====
# Optional: UIDAI API Configuration (Required for production)
# Contact UIDAI to obtain API credentials
# UIDAI_API_KEY=your-uidai-api-key-here
# UIDAI_API_URL=https://api.uidai.gov.in

# ===== SMS GATEWAY =====
# For real SMS delivery, configure one of these providers:

# 1. TWILIO (Popular globally, works well in India)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# 2. AWS SNS (Amazon Simple Notification Service)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SNS_REGION=ap-south-1

# 3. Custom SMS Provider (E.g., MSG91, Niyogin, etc.)
# SMS_GATEWAY_API_KEY=your-sms-gateway-key
# SMS_GATEWAY_URL=https://api.your-sms-provider.com
# SMS_GATEWAY_SENDER_ID=BHARATVOTE

# ===== APPLICATION CONFIG =====
# Application name for OTP messages
APP_NAME=BharatVote

# OTP Configuration (in seconds)
OTP_VALIDITY=900           # 15 minutes
OTP_MAX_ATTEMPTS=3         # Maximum wrong attempts
OTP_MIN_LENGTH=6          # OTP digit length
OTP_RESEND_INTERVAL=60    # Minimum wait between resends (in seconds)

# Database
DATABASE_URL=./database.sqlite

# ===== VOTING SYSTEM =====
# Election parameters
VOTING_START_TIME=2026-02-15T10:00:00Z
VOTING_END_TIME=2026-02-15T18:00:00Z
ELECTION_NAME=National Parliament Elections 2026

# ===== SECURITY =====
# Enable HTTPS in production
HTTPS_ENABLED=false

# JWT Secret (if implementing token-based auth)
# JWT_SECRET=your-super-secret-key-min-32-chars

# ===== LOGGING =====
# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# Enable audit logging
AUDIT_LOGGING=true

# Gemini AI assistant API key
# GEMINI_API_KEY=your-gemini-api-key-here

# ===== DEVELOPMENT =====
# Set to 'development' or 'production'
NODE_ENV=development

# Enable console logging
CONSOLE_LOGGING=true

# ===== NOTES =====
# For development/testing:
# - Leave UIDAI_API_KEY and SMS_GATEWAY_API_KEY empty
# - System will simulate OTP (check browser console)
# - Check server logs for demo OTP

# For production:
# - All API keys must be configured
# - Enable HTTPS
# - Set NODE_ENV=production
# - Configure proper error handling
# - Enable audit logging
