# Environment Configuration
# Copy this file to .env or .env.local and fill in your values

# ===== GOOGLE GEMINI API =====
# Required for the AI Election Assistant
GOOGLE_GENERATIVE_AI_API_KEY=your-api-key-here

# ===== SERVER CONFIGURATION =====
PORT=3000
NODE_ENV=development

# ===== SMS GATEWAY (Optional - for real delivery) =====
# For real SMS delivery, configure one of these providers:

# 1. TWILIO
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ===== FIREBASE CONFIGURATION (Recommended for Secure SMS OTP) =====
# Get these values from your Firebase Console -> Project Settings -> General
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ===== APPLICATION CONFIG =====
# Application name for OTP messages
APP_NAME=BharatVote

# OTP Configuration (in seconds)
OTP_VALIDITY=900           # 15 minutes
OTP_MAX_ATTEMPTS=3         # Maximum wrong attempts
OTP_MIN_LENGTH=6          # OTP digit length
OTP_RESEND_INTERVAL=60    # Minimum wait between resends (in seconds)

# Database
DATABASE_URL=./database.sqlite

# ===== VOTING SYSTEM =====
# Election parameters
VOTING_START_TIME=2026-02-15T10:00:00Z
VOTING_END_TIME=2026-02-15T18:00:00Z
ELECTION_NAME=National Parliament Elections 2026

# ===== SECURITY =====
# Enable HTTPS in production
HTTPS_ENABLED=false

# JWT Secret (if implementing token-based auth)
# JWT_SECRET=your-super-secret-key-min-32-chars

# ===== LOGGING =====
# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# Enable audit logging
AUDIT_LOGGING=true

# Gemini AI assistant API key
# GEMINI_API_KEY=your-gemini-api-key-here

# ===== DEVELOPMENT =====
# Set to 'development' or 'production'
NODE_ENV=development

# Enable console logging
CONSOLE_LOGGING=true

# ===== NOTES =====
# For development/testing:
# - All Firebase configuration must be provided for Phone Authentication to work.
# - reCAPTCHA is used in invisible mode to prevent spam.

# For production:
# - All API keys must be configured
# - Enable HTTPS
# - Set NODE_ENV=production
# - Configure proper error handling
# - Enable audit logging
