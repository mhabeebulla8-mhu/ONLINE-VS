# Environment Configuration for BharatVote
# Copy this file to .env and configure for your environment

# ===== NODE ENVIRONMENT =====
NODE_ENV=development

# ===== AADHAAR OTP VERIFICATION =====
# UIDAI API Configuration (leave empty for demo mode)
UIDAI_API_KEY=
UIDAI_BASE_URL=https://uidai.gov.in

# SMS Gateway Configuration (leave empty for demo mode)
SMS_GATEWAY_API_KEY=
SMS_GATEWAY_URL=https://api.sms-gateway.com

# Application name for OTP messages
APP_NAME=BharatVote

# Gemini AI assistant configuration
GEMINI_API_KEY=

# OTP Configuration (in seconds)
OTP_VALIDITY=900           # 15 minutes
OTP_MAX_ATTEMPTS=3         # Maximum wrong attempts
OTP_MIN_LENGTH=6          # OTP digit length
OTP_RESEND_INTERVAL=60    # Minimum wait between resends (in seconds)

# ===== DEVELOPMENT =====
# Enable console logging
CONSOLE_LOGGING=true

# ===== DATABASE =====
DATABASE_PATH=./database.sqlite

# ===== SECURITY =====
# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ===== NOTES =====
# For development/testing:
# - Leave UIDAI_API_KEY and SMS_GATEWAY_API_KEY empty
# - System will simulate OTP (check browser console)
# - Check server logs for demo OTP

# For production:
# - All API keys must be configured
# - Enable HTTPS
# - Set NODE_ENV=production
# - Configure proper error handling
# - Enable audit logging